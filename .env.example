# Copy to .env for local Docker Compose. These defaults work out of the box.
POSTGRES_USER=prep
POSTGRES_PASSWORD=prep
POSTGRES_DB=prep
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend reads this; compose injects it.
DATABASE_URL=postgresql+psycopg://prep:prep@db:5432/prep

# AI auto-fill of topic content (learning points + questions). Optional — leave
# the relevant secret blank to disable. Restart the backend after changes.
#
# Which backend Claude is called through:
#   api          -> Anthropic API, billed to CREDITS (uses ANTHROPIC_API_KEY).
#                   Used by docker-compose.prod.yml (servers).
#   subscription -> Claude Code CLI, billed to your Max/Pro PLAN, not credits
#                   (uses CLAUDE_CODE_OAUTH_TOKEN). Used by docker-compose.dev.yml
#                   (local laptop only — the dev backend image bundles the CLI).
# The chosen overlay sets this; you normally don't edit it here.
LLM_PROVIDER=api

# --- api provider (prod/servers) ---
# MORE SECURE: leave this BLANK and store the key in the macOS Keychain instead,
# then launch via `./scripts/run.sh up -d` (it injects the key at runtime so the
# secret never lives in this file). One-time:
#   security add-generic-password -U -a "$USER" -s forge-anthropic-api-key -w
ANTHROPIC_API_KEY=

# --- subscription provider (local dev only) ---
# Long-lived OAuth token tied to your Claude Max/Pro subscription. Mint it once:
#   claude setup-token
# then paste the result here. Calls bill against your plan, not API credits.
# Only used when LLM_PROVIDER=subscription (the dev overlay). NEVER commit a real
# token; .env is gitignored.
CLAUDE_CODE_OAUTH_TOKEN=

# Optional model override (defaults to claude-sonnet-4-6; claude-haiku-4-5 is cheaper/faster,
# claude-opus-4-8 is highest quality). Applies to both providers. On the api path,
# ANTHROPIC_MAX_TOKENS must be <= the model's max output (Sonnet 4.6 = 128k, Haiku 4.5
# = 64k) — lower it if you switch to Haiku. Ignored on the subscription path.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=100000

# Frontend (Vite) -> backend base URL, used in the browser.
# Leave BLANK: the frontend auto-derives the API host from the URL you open it
# with, so localhost AND LAN access (e.g. http://10.0.0.24:5173) both work.
# Only set this to override (e.g. a remote/tunneled backend).
VITE_API_BASE=
