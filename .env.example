# Copy to .env for local Docker Compose. These defaults work out of the box.
POSTGRES_USER=prep
POSTGRES_PASSWORD=prep
POSTGRES_DB=prep
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend reads this; compose injects it.
DATABASE_URL=postgresql+psycopg://prep:prep@db:5432/prep

# Frontend (Vite) -> backend base URL, used in the browser.
VITE_API_BASE=http://localhost:8001
